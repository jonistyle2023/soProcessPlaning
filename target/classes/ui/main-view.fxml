<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.TextFlow?>
<?import javafx.scene.text.Text?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.MainViewController"
      stylesheets="@styles.css">
    <padding>
        <!-- Padding general para que nada toque los bordes -->
        <Insets bottom="15" left="15" right="15" top="15"/>
    </padding>

    <!-- Fila Superior de Controles -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <children>
            <Label text="Algoritmo de Planificación:">
                <font>
                    <Font name="System Bold" size="14.0"/>
                </font>
            </Label>
            <ComboBox fx:id="algoritmoComboBox" prefWidth="200.0"/>
            <HBox fx:id="quantumBox" alignment="CENTER_LEFT" spacing="5" visible="false" managed="false">
                <children>
                    <Label text="Quantum:"/>
                    <Spinner fx:id="quantumSpinner" prefWidth="70.0" editable="false"/>
                </children>
            </HBox>
            <Button mnemonicParsing="false" onAction="#onEjecutar" text="Ejecutar Algoritmo"
                    styleClass="button-primary"/>
            <!-- Este HBox empuja los botones de exportación a la derecha -->
            <HBox alignment="CENTER_RIGHT" spacing="10" HBox.hgrow="ALWAYS">
                <Button mnemonicParsing="false" onAction="#onExportarExcel" text="Exportar a Excel"
                        styleClass="button-secondary"/>
                <Button mnemonicParsing="false" onAction="#onExportarPDF" text="Exportar a PDF"
                        styleClass="button-secondary"/>
            </HBox>
        </children>
        <padding>
            <Insets bottom="10"/>
        </padding>
    </HBox>

    <BorderPane VBox.vgrow="ALWAYS">
        <center>
            <VBox spacing="10" BorderPane.alignment="CENTER">
                <children>
                    <Label text="Tabla de Procesos">
                        <font>
                            <Font name="System Bold" size="12.0"/>
                        </font>
                    </Label>
                    <TableView fx:id="tablaProcesos" editable="true" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colNombre" prefWidth="75.0" text="Proceso"/>
                            <TableColumn fx:id="colLlegada" prefWidth="75.0" text="Llegada"/>
                            <TableColumn fx:id="colEjecucion" prefWidth="75.0" text="Ejecución"/>
                            <TableColumn fx:id="colComienzo" prefWidth="75.0" text="Comienzo"/>
                            <TableColumn fx:id="colFin" prefWidth="75.0" text="Fin"/>
                            <TableColumn fx:id="colRetorno" prefWidth="75.0" text="Retorno"/>
                            <TableColumn fx:id="colEspera" prefWidth="75.0" text="Espera"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                    <HBox alignment="CENTER" spacing="9.0">
                        <children>
                            <Button onAction="#onAgregarProceso" text="Agregar Proceso"
                                    styleClass="button-info"/>
                            <Button onAction="#onGenerarAleatorio" text="Generar Aleatorios"
                                    styleClass="button-warning"/>
                            <Button onAction="#onLimpiarProcesos" text="Limpiar Tabla"
                                    styleClass="button-danger"/>
                        </children>
                    </HBox>
                </children>
            </VBox>
        </center>
    </BorderPane>

    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <children>
            <Label text="Diagrama de Gantt">
                <font>
                    <Font name="System Bold" size="14.0"/>
                </font>
            </Label>
            <ScrollPane hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" fitToHeight="true" fitToWidth="true"
                        styleClass="gantt-scroll"
                        VBox.vgrow="ALWAYS">
                <content>
                    <HBox fx:id="ganttBox" alignment="BOTTOM_LEFT" spacing="0" styleClass="gantt-box"
                        HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets bottom="5" left="5" right="5" top="5"/>
                        </padding>
                    </HBox>
                </content>
            </ScrollPane>
        </children>
        <padding>
            <Insets top="10.0"/>
        </padding>
    </VBox>

    <!-- Footer -->
    <HBox spacing="10">
        <children>
            <!-- Izquierda: Nombre y versión -->
            <TextFlow>
                <Text text="Software Planificador de Procesos " styleClass="footer-text"/>
                <Text text="v1.2.0" styleClass="footer-text-bold"/>
            </TextFlow>
            <!-- Centro: Espaciador -->
            <HBox HBox.hgrow="ALWAYS"/>
            <!-- Derecha: Créditos -->
            <TextFlow>
                <Text text="Desarrollado por " styleClass="footer-text"/>
                <Text text="Grupo #5 - Sistemas operativos 3/1" styleClass="footer-text-bold"/>
            </TextFlow>
        </children>
        <padding>
            <Insets top="10"/>
        </padding>
    </HBox>


</VBox>